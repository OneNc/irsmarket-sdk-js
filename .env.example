# IRSMarket SDK Environment Variables

# Your IRSMarket API Credentials
IRS_API_KEY=your_api_key_here
IRS_API_SECRET=your_api_secret_here

# Optional: Custom base URL
IRS_BASE_URL=https://api.irsmarket.com/v1

# Optional: Request timeout in milliseconds
IRS_TIMEOUT=30000

# Webhook Configuration
WEBHOOK_URL=https://your-domain.com/webhook/irsmarket
WEBHOOK_PORT=3000
