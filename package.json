{
    "name": "irsmarket-sdk-js",
    "version": "1.0.1",
    "description": "Node.js SDK untuk integrasi API IRSMarket - Platform jual beli pulsa, kuota, voucher game, dan produk digital lainnya",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "watch": "tsc -w",
        "test": "jest --testPathIgnorePatterns=test-balance.ts",
        "test:watch": "jest --watch",
        "lint": "eslint src/**/*.ts",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "irsmarket",
        "api",
        "pulsa",
        "kuota",
        "voucher",
        "game",
        "ppob",
        "token",
        "listrik",
        "digital"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/OneNc/irsmarket-sdk-js.git"
    },
    "bugs": {
        "url": "https://github.com/OneNc/irsmarket-sdk-js/issues"
    },
    "homepage": "https://github.com/OneNc/irsmarket-sdk-js#readme",
    "author": "OneNc",
    "license": "MIT",
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md",
        "LICENSE"
    ],
    "dependencies": {
        "axios": "^1.6.0",
        "dotenv": "^17.3.1"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/node": "^20.0.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "eslint": "^8.0.0",
        "jest": "^29.5.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.0.0"
    },
    "engines": {
        "node": ">=14.0.0"
    }
}